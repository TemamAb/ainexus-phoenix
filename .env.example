# AI-NEXUS GASLESS CONFIGURATION
# ERC-4337 Account Abstraction Mode
# No wallet funding required - Pilmico Paymaster

MODE=gasless
ERC4337_ENABLED=true
PAYMASTER=pilmico
GAS_SPONSORSHIP=true
WALLET_FUNDING_REQUIRED=false

# Network Configuration
NETWORK=mainnet
CHAIN_ID=1

# Pilmico Paymaster Endpoints
PAYMASTER_URL=https://api.pilmico.com/v1/sponsor
BUNDLER_URL=https://api.pilmico.com/v1/bundler

# Exchange Configuration
EXCHANGES=uniswap,pancakeswap,curve,sushiswap,balancer
FLASH_LOAN_ENABLED=true
ARBITRAGE_AGGRESSION=high

# Risk Management
MAX_POSITION_SIZE=5000000
DAILY_LOSS_LIMIT=100000
CIRCUIT_BREAKER_ENABLED=true
